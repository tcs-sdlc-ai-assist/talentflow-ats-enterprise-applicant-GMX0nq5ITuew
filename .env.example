# TalentFlow ATS - Environment Configuration
# Copy this file to .env and fill in your values

# Database connection URL
# For SQLite (default for development):
DATABASE_URL=sqlite+aiosqlite:///./talentflow.db
# For PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/talentflow

# Secret key for JWT token signing and session security
# Generate a secure key with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-secret-key

# Debug mode (set to False in production)
DEBUG=True

# Default admin account created on first startup
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changeme123